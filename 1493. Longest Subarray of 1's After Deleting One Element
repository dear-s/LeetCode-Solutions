class Solution:
    def longestSubarray(self, nums: List[int]) -> int:

        # we can have atmost 1 ZERO, and ALL ONEs

        count = 0
        res = 0
        zero = False
        lastZeroIndex = -1
        
        i = 0
        while i < len(nums):
            # print("index: ", i, " count: ", count, " zero: ", zero, " zIndex: ", lastZeroIndex)
            if nums[i] == 1:
                count += 1
                i += 1
            else:
                if zero == True:
                    # already counted and came again, then pick the index after last zero +1
                    i = lastZeroIndex+1
                    count = 0 # reset this count array
                    zero = False # reset

                else:
                    # count this zero, update lastZeroIndex
                    zero = True
                    lastZeroIndex = i
                    i += 1
            res = max(res, count)
        
        if zero is False:
            return res-1
        return res
