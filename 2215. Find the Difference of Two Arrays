class Solution:
    def findDifference(self, nums1: List[int], nums2: List[int]) -> List[List[int]]:

        # Using hashmap approach instead of lists - more optimal
        dic1 = {}
        dic2 = {}

        for i in nums1:
            dic1[i] = True
        cDic1 = dic1.copy()
        
        for j in nums2:
            dic2[j] = True
        cDic2 = dic2.copy()

        for k,v in dic1.items():
            if k in dic2:
                # remove from both dictionaries
                cDic1.pop(k)
                cDic2.pop(k)
        
        # all ready
        a = []
        b = []
        for k,v in cDic1.items():
            a.append(k)
        for k,v in cDic2.items():
            b.append(k)
        
        return [a,b]


