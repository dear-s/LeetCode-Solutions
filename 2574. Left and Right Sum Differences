class Solution:
    def leftRightDifference(self, nums: List[int]) -> List[int]:
        
        summ = sum(nums)
        output = []
        lsum= 0

        for i in range(len(nums)):
            fR = summ - lsum - nums[i]
            fL = lsum
            output.append(abs(fL - fR))
            lsum += nums[i]
        return output
